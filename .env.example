# ChromaDB connection
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Company context
COMPANY_STATE_CODE=29

# Sync staleness threshold (hours)
SYNC_STALE_HOURS=6

# Confidence thresholds
HARD_KEY_THRESHOLD=0.90
FILTER_THRESHOLD=0.70
HINT_THRESHOLD=0.50
AUTO_MAP_THRESHOLD=0.88
SUGGEST_THRESHOLD=0.70
REVIEW_THRESHOLD=0.50

# Debug mode
DEBUG=false
