# ERPNext connection (Frappe Cloud or self-hosted)
ERPNEXT_URL=https://your-site.frappe.cloud
ERPNEXT_API_KEY=your-api-key-here
ERPNEXT_API_SECRET=your-api-secret-here

# ChromaDB connection
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Company context (country + region for tax scope)
COMPANY_COUNTRY=OM
COMPANY_REGION_CODE=

# Sync staleness threshold (hours)
SYNC_STALE_HOURS=6

# Confidence thresholds
HARD_KEY_THRESHOLD=0.90
FILTER_THRESHOLD=0.70
HINT_THRESHOLD=0.50
AUTO_MAP_THRESHOLD=0.88
SUGGEST_THRESHOLD=0.70
REVIEW_THRESHOLD=0.50

# Logging
LOG_FORMAT=console
LOG_LEVEL=INFO

# Debug mode
DEBUG=false
